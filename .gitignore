# Paperclip (cloned dependency, not our code)
paperclip/
# But track our Paperclip integration scripts
!scripts/paperclip/
!scripts/paperclip/test_heartbeat.py

# Code / build artifacts
node_modules/
*.log
__pycache__/
*.pyc
*.pyo
.venv/

# Editor / OS
.vscode/
.idea/
Thumbs.db
.DS_Store

# Claude runtime
.claude/worktrees/
.claude/.credentials.json
.claude/scheduled_tasks.lock

