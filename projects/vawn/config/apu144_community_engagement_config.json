{
  "monitor_info": {
    "name": "APU-144 Community Engagement Monitor",
    "version": "1.0.0",
    "created_by": "Dex - Community Agent",
    "focus": "Community Health & Sustainable Engagement",
    "last_updated": "2026-04-13"
  },
  "monitoring_settings": {
    "check_interval_seconds": 45,
    "platforms": ["instagram", "tiktok", "x", "threads", "bluesky"],
    "session_timeout_minutes": 30,
    "auto_recovery_enabled": true,
    "community_care_mode": true
  },
  "community_health_thresholds": {
    "community_health_score": {
      "excellent": 0.85,
      "good": 0.70,
      "warning": 0.50,
      "critical": 0.30
    },
    "engagement_quality": {
      "excellent": 0.80,
      "good": 0.65,
      "warning": 0.45,
      "critical": 0.25
    },
    "conversation_depth": {
      "excellent": 0.75,
      "good": 0.60,
      "warning": 0.40,
      "critical": 0.20
    },
    "sentiment_balance": {
      "excellent": 0.70,
      "good": 0.50,
      "warning": 0.20,
      "critical": -0.20
    },
    "growth_sustainability": {
      "excellent": 0.85,
      "good": 0.70,
      "warning": 0.50,
      "critical": 0.30
    }
  },
  "scoring_weights": {
    "conversation_depth": 0.25,
    "sentiment_balance": 0.20,
    "community_cohesion": 0.20,
    "engagement_authenticity": 0.15,
    "growth_sustainability": 0.15,
    "moderator_effectiveness": 0.05
  },
  "alert_settings": {
    "enable_real_time_alerts": true,
    "alert_channels": ["database", "log_file", "console"],
    "auto_resolve_enabled": true,
    "escalation_enabled": true,
    "escalation_threshold_minutes": 15,
    "alert_priorities": {
      "critical": {
        "community_health_score_below": 0.30,
        "negative_sentiment_threshold": -0.50,
        "engagement_quality_below": 0.25
      },
      "high": {
        "community_health_score_below": 0.50,
        "negative_sentiment_threshold": -0.20,
        "engagement_quality_below": 0.45
      },
      "medium": {
        "community_health_score_below": 0.70,
        "engagement_quality_below": 0.65
      }
    }
  },
  "engagement_quality_settings": {
    "meaningful_conversation_indicators": {
      "response_length_above_chars": 100,
      "conversation_turns_above": 2,
      "time_between_responses_max_minutes": 30,
      "contains_questions": true,
      "contains_personal_sharing": true
    },
    "superficial_interaction_indicators": {
      "single_emoji_responses": true,
      "generic_responses": true,
      "promotional_content_only": true,
      "response_length_below_chars": 20
    }
  },
  "data_retention": {
    "database_retention_days": 90,
    "log_file_max_entries": 1000,
    "alert_history_days": 30,
    "health_metrics_retention_days": 365
  },
  "integration_settings": {
    "paperclip_platform_enabled": true,
    "cross_platform_tracking": true,
    "legacy_apu_compatibility": true,
    "api_rate_limits": {
      "instagram": 100,
      "tiktok": 150,
      "x": 300,
      "threads": 200,
      "bluesky": 250
    }
  },
  "community_care_features": {
    "proactive_intervention": true,
    "sentiment_trend_analysis": true,
    "member_onboarding_tracking": true,
    "conversation_facilitation": true,
    "community_growth_optimization": true,
    "authenticity_verification": true
  },
  "reporting_settings": {
    "daily_health_reports": true,
    "weekly_trend_analysis": true,
    "monthly_community_summary": true,
    "real_time_dashboard": true,
    "export_formats": ["json", "csv", "pdf"]
  }
}