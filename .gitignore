# Paperclip (cloned dependency, not our code)
paperclip/
# But track our Paperclip integration scripts
!scripts/paperclip/
!scripts/paperclip/test_heartbeat.py

# Code / build artifacts
node_modules/
*.log
__pycache__/
*.pyc
*.pyo
.venv/

# Editor / OS
.vscode/
.idea/
Thumbs.db
.DS_Store

# Claude runtime
.claude/worktrees/
.claude/.credentials.json
.claude/scheduled_tasks.lock

# Ruflo / agentdb runtime artifacts
*.rvf
*.rvf.lock
ruvector.db
agentdb.rvf
agentdb.rvf.lock

# Lock files
.text_post_lock_*

# Pipeline outputs (not tracked in vault history)
pipeline/output/

# Secrets (never commit)
**/credentials.json
**/credentials.*.json
.env
.env.*
*.key
*.pem
*.pfx
*.p12

# Projects with their own git repos
projects/apulu-prompt-generator/.git/

# Live agent-managed working dirs that have their own .gitignore + repo
# (junction in this case; track the orchestration scripts in scripts/paperclip/ instead)
projects/vawn/

# Atomic-write leftovers (e.g., credentials.json.tmp.35052)
**/credentials.json.tmp.*
**/*.tmp.[0-9]*

# Auto-generated agent output (daily-cadence files).
# Live on disk for context but produce too much git churn to track.
# _index.md hubs stay visible by not matching these patterns.
research/vawn/briefings/Daily Briefing -- *.md
research/vawn/briefings/Health -- *.md
research/vawn/briefings/System Health -- *.md
research/vawn/discovery/Discovery Brief -- *.md
research/vawn/discovery/*-playlist-monitor.md
research/vawn/discovery/*-artist-discovery.md
research/vawn/discovery/YouTube Pipeline -- *.md
research/vawn/discovery/Research Pipeline — *.md
research/vawn/discovery/Research Pipeline -- *.md
research/vawn/discovery/Instagram Pipeline -- *.md
research/vawn/discovery/TikTok Pipeline -- *.md
research/vawn/discovery/X Pipeline -- *.md
research/vawn/discovery/Rhythm Shortlist -- *.md
research/vawn/discovery/*_results.json
research/vawn/discovery/discovery_brief.json
research/vawn/competitive/*-competitive-report.md
research/vawn/finance/*-revenue-check.md
research/vawn/ops-digest/*-weekly-ops.md
research/vawn/briefings/*_results.json
research/vawn/ideation/*_results.json
research/vawn/ideation/Content Ideation — *.md
research/vawn/ideation/Content Ideation -- *.md
research/vawn/ar-intel/Cultural Radar -- *.md
