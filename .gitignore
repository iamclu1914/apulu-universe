*.rvf
*.rvf.lock
ruvector.db
agentdb.rvf
agentdb.rvf.lock

# Lock files
.text_post_lock_*

# Pipeline outputs (not tracked in vault history)
pipeline/output/

# Secrets (never commit)
**/credentials.json
**/credentials.*.json
.env
.env.*
*.key
*.pem
*.pfx
*.p12

# Projects with their own git repos
projects/apulu-prompt-generator/.git/

# Obsidian runtime state (churn on every app use)
.obsidian/graph.json
.obsidian/workspace.json
.obsidian/workspaces.json
