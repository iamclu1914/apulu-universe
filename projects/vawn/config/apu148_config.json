      "save_rate_ig": {
        "concerning": 0.01,
        "average": 0.025,
        "strong": 0.05
      },
      "share_rate_tt": {
        "concerning": 0.005,
        "average": 0.015,
        "strong": 0.03
      },
      "comments_per_post": {
        "concerning": 2,
        "average": 10,
        "strong": 20
      }
    }
  },
  "reporting": {
